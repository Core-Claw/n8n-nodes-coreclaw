{
	"name": "n8n-nodes-coreclaw",
	"version": "0.3.0",
	"description": "n8n community nodes for CoreClaw API v2 workers, worker runs, saved tasks, results, exports, logs, account data, and run callbacks",
	"license": "MIT",
	"homepage": "https://github.com/Core-Claw/n8n-nodes-coreclaw",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"coreclaw",
		"scraper",
		"web-scraping",
		"data-extraction"
	],
	"author": {
		"name": "CoreClaw",
		"email": "support@coreclaw.com"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Core-Claw/n8n-nodes-coreclaw.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"dev:local": "N8N_SECURE_COOKIE=false n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease",
		"test": "jest --config jest.config.js --passWithNoTests",
		"test:live": "cross-env CORECLAW_LIVE_TESTS=1 jest --config jest.config.js nodes/CoreClaw/__tests__/e2e.live.test.ts"
	},
	"engines": {
		"node": ">=20.15"
	},
	"files": [
		"dist",
		"CHANGELOG.md"
	],
	"publishConfig": {
		"access": "public"
	},
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/CoreClawApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/CoreClaw/CoreClaw.node.js",
			"dist/nodes/CoreClawTrigger/CoreClawTrigger.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"@types/jest": "^30.0.0",
		"cross-env": "^10.1.0",
		"eslint": "9.32.0",
		"jest": "^30.4.2",
		"nock": "^14.0.16",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"ts-jest": "^29.4.11",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
